# Core local runtime
DATABASE_URL="postgresql://envoy:envoy@localhost:5432/envoy"
REDIS_URL="redis://localhost:6379"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-string"
ENVOY_SECRET_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Required for Gmail connect
GMAIL_OAUTH_CLIENT_ID=""
GMAIL_OAUTH_CLIENT_SECRET=""
GMAIL_OAUTH_REDIRECT_URI="http://localhost:3000/api/integrations/gmail/callback"
GMAIL_OAUTH_STATE_SECRET="replace-with-a-second-long-random-string"

# Optional: enable Gmail Pub/Sub live sync
GMAIL_PUBSUB_TOPIC=""
GMAIL_PUBSUB_VERIFICATION_TOKEN=""
GMAIL_PUBSUB_AUDIENCE=""
GMAIL_PUBSUB_SERVICE_ACCOUNT_EMAIL=""

# Optional: enable agent draft generation / preview
OPENAI_API_KEY=""
OPENAI_DRAFT_MODEL="gpt-4.1-mini"
OPENAI_BASE_URL=""

# Optional worker tuning
WORKER_ID="local-worker"
WORKER_CONCURRENCY="5"
