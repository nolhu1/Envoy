{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": "../..",
    "paths": {
      "@/*": ["apps/web/src/*"],
      "@envoy/connectors": ["packages/connectors/src/index.ts"],
      "@envoy/db": ["packages/db/src/index.ts"],
      "@envoy/events": ["packages/events/src/index.ts"],
      "@envoy/types": ["packages/types/src"],
      "@envoy/ui": ["packages/ui/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
