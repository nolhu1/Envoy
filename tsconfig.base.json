  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@envoy/db": ["packages/db/src"],
      "@envoy/types": ["packages/types/src"],
      "@envoy/events": ["packages/events/src"]
    }
  }
}